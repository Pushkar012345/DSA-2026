/**
 * @param {number[]} nums
 * @param {number} k
 * @return {void} Do not return anything, modify nums in-place instead.
 */
var rotate = function(nums, k) {
    let n=nums.length;

    k=k%n; //handle= k>n

    let rotated=nums.slice(n-k).concat(nums.slice(0,n-k));

    for(let i=0;i<n;i++)
    {
        nums[i]=rotated[i];
    }

};
